<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>YAKUZAXSILENCE</title>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
<style>
*{margin:0;padding:0;box-sizing:border-box;font-family:'Segoe UI',sans-serif}
body{background:#000;color:#fff;overflow:hidden}
.page{width:100%;height:100vh;display:flex;align-items:center;justify-content:center;transition:0.5s}
#dashboard{display:none;background:linear-gradient(180deg,#8b0000 0%,#000 100%);flex-direction:row}

/* LOGIN PAGE */
#login{background:radial-gradient(circle at center,#1a0033 0%,#000 100%)}
.login-box{width:90%;max-width:380px;background:#0a0a0a;border:2px solid #0040ff;border-radius:20px;padding:30px;text-align:center;box-shadow:0 0 30px #0040ff,0 0 60px #8b00ff}
.login-box .logo{width:70px;height:70px;border:3px solid #0040ff;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 15px;font-size:40px;font-weight:900;color:#0040ff;box-shadow:0 0 20px #0040ff}
.login-box h1{font-size:22px;margin-bottom:5px}
.login-box p{font-size:12px;color:#aaa;margin-bottom:20px;letter-spacing:1px}
.login-box input{width:100%;padding:14px;border-radius:12px;border:2px solid #333;background:#111;color:#fff;margin-bottom:15px;outline:none;font-size:14px}
.login-box input:focus{border-color:#0040ff;box-shadow:0 0 10px #0040ff}
.btn{width:100%;padding:14px;border:none;border-radius:12px;font-weight:700;font-size:15px;cursor:pointer;margin-bottom:12px;transition:0.3s}
.btn-login{background:linear-gradient(90deg,#ff0040,#0040ff);color:#000;box-shadow:0 0 15px #0040ff}
.btn-login:active{transform:scale(0.97)}
.btn-admin{border:2px solid #0040ff;background:transparent;color:#fff}
.btn-admin:active{transform:scale(0.97)}

/* DASHBOARD */
.sidebar{width:70px;background:#0a0a0a;display:flex;flex-direction:column;align-items:center;padding:20px 0;gap:25px;border-right:1px solid #222}
.sidebar i{font-size:22px;color:#777;cursor:pointer;transition:0.3s}
.sidebar i.active,.sidebar i:hover{color:#ff0040}
.main{flex:1;padding:20px;overflow-y:auto}
.header{display:flex;justify-content:space-between;align-items:center;margin-bottom:20px}
.time{font-size:32px;font-weight:700}
.date{font-size:12px;color:#aaa}
.top-card{background:#111;padding:15px;border-radius:15px;display:flex;justify-content:space-between;align-items:center;margin-bottom:20px}
.badge{background:#ff0040;padding:5px 12px;border-radius:20px;font-size:12px;font-weight:700}
.stats{display:grid;grid-template-columns:1fr 1fr;gap:15px;margin-bottom:20px}
.stat-card{background:#111;padding:15px;border-radius:15px}
.stat-card h3{font-size:12px;color:#aaa;margin-bottom:8px}
.stat-card .num{font-size:24px;font-weight:700}
.info-card{background:#111;padding:15px;border-radius:15px;display:flex;align-items:center;gap:12px;margin-bottom:12px}
.info-icon{width:40px;height:40px;background:#220000;border-radius:10px;display:flex;align-items:center;justify-content:center;color:#ff0040}
.quick{display:grid;grid-template-columns:1fr 1fr;gap:15px}
.q-card{background:#111;padding:20px;border-radius:15px;text-align:center;cursor:pointer}
.q-card i{font-size:28px;margin-bottom:8px}
.q-card .red{color:#ff0040}
.q-card .blue{color:#0040ff}
</style>
</head>
<body>

<!-- PAGE 1 LOGIN -->
<div class="page" id="login">
  <div class="login-box">
    <div class="logo">X</div>
    <h1>YAKUZAXSILENCE</h1>
    <p>PREMIUM SECURITY SYSTEM</p>
    <input type="password" id="key" placeholder="MASUKKAN ACCESS KEY">
    <button class="btn btn-login" onclick="login()">LOGIN</button>
    <button class="btn btn-admin" onclick="window.open('https://wa.me/628000000000','_blank')">💎 BELI AKSES / KEY KE ADMIN</button>
  </div>
</div>

<!-- PAGE 2 DASHBOARD -->
<div class="page" id="dashboard">
  <div class="sidebar">
    <i class="fa-solid fa-house active"></i>
    <i class="fa-solid fa-screwdriver-wrench"></i>
    <i class="fa-brands fa-whatsapp"></i>
    <i class="fa-solid fa-desktop"></i>
    <i class="fa-solid fa-bell"></i>
    <i class="fa-solid fa-bars"></i>
  </div>
  <div class="main">
    <div class="header">
      <div>
        <div class="time" id="clock">11:59</div>
        <div class="date">MONDAY, JULY 13</div>
      </div>
      <div style="display:flex;gap:10px">
        <div style="width:40px;height:40px;background:#222;border-radius:50%;display:flex;align-items:center;justify-content:center"><i class="fa-solid fa-bell"></i></div>
        <div style="width:40px;height:40px;background:#ff0040;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:700">Y</div>
      </div>
    </div>

    <div class="top-card">
      <div>
        <h2>Yakuzax X Silenx</h2>
        <p style="font-size:12px;color:#aaa">Developer @yan suka toblut</p>
      </div>
      <div class="badge">LIVE</div>
    </div>

    <h3 style="margin-bottom:10px">YakuzaUser</h3>
    <p style="font-size:12px;color:#aaa;margin-bottom:15px">Welcome back</p>
    
    <h4 style="font-size:12px;color:#aaa;margin-bottom:10px">STATISTICS</h4>
    <div class="stats">
      <div class="stat-card">
        <h3>Online Users</h3>
        <div style="display:flex;justify-content:space-between;align-items:center">
          <div class="num">1.2k</div>
          <i class="fa-solid fa-users" style="color:#ff0040;font-size:24px"></i>
        </div>
      </div>
      <div class="stat-card">
        <h3>Active Senders</h3>
        <div style="display:flex;justify-content:space-between;align-items:center">
          <div class="num">1.1k</div>
          <i class="fa-solid fa-message" style="color:#0040ff;font-size:24px"></i>
        </div>
      </div>
    </div>

    <h4 style="font-size:12px;color:#aaa;margin:20px 0 10px">ACCOUNT INFORMATION</h4>
    <div class="info-card"><div class="info-icon"><i class="fa-solid fa-user"></i></div><div><div style="font-size:12px;color:#aaa">Username</div><b>DEVELOPER</b></div></div>
    <div class="info-card"><div class="info-icon"><i class="fa-solid fa-tag"></i></div><div><div style="font-size:12px;color:#aaa">Role</div><b>Admin</b></div></div>
    <div class="info-card"><div class="info-icon"><i class="fa-solid fa-calendar"></i></div><div><div style="font-size:12px;color:#aaa">Expires</div><b>2026-12-31</b></div></div>

    <h4 style="font-size:12px;color:#aaa;margin:20px 0 10px">QUICK ACTIONS</h4>
    <div class="quick">
      <div class="q-card" onclick="alert('Fitur My Senders')">
        <i class="fa-solid fa-paper-plane red"></i>
        <div><b>My Senders</b></div>
        <div style="font-size:12px;color:#aaa">Manage senders</div>
      </div>
      <div class="q-card" onclick="alert('Developer @YanxXflow')">
        <i class="fa-solid fa-code blue"></i>
        <div><b>Developer</b></div>
        <div style="font-size:12px;color:#aaa">@YanxXflow</div>
      </div>
    </div>
  </div>
</div>

<script>
// LOGIN SYSTEM
function login(){
  let key = document.getElementById('key').value;
  if(key == "vip1" || key == "admin"){ // ganti key disini
    document.getElementById('login').style.display = 'none';
    document.getElementById('dashboard').style.display = 'flex';
    updateClock();
    setInterval(updateClock,1000);
  }else{
    alert('KEY SALAH!');
  }
}

// JAM OTOMATIS
function updateClock(){
  let d = new Date();
  let h = d.getHours().toString().padStart(2,'0');
  let m = d.getMinutes().toString().padStart(2,'0');
  document.getElementById('clock').innerText = h+':'+m;
}
</script>
</body>
</html>
